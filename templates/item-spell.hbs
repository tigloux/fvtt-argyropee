<div class="item-content-wrapper" style="height: 100%; margin-top: 10px">
    
    {{!-- ONGLET 0 : DESCRIPTION --}}
    <div class="tab {{#if (eq tab.id 'description')}}active{{/if}}" data-tab="description" style="height: 100%;">
        <section class="sheet-body" style="padding: 10px;">
            <fieldset class="item-fieldset">
                <legend><i class="fas fa-book-open"></i> Formule et Effets du sort</legend>
                <div style="min-height: 150px; margin-top: 10px;">
                    <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" toggled="true">
                        {{{enrichedDescription}}}
                    </prose-mirror>
                </div>
            </fieldset>
        </section>
    </div>

    {{!-- ONGLET 1 : DÉTAILS --}}
    <div class="tab {{#if (eq tab.id 'body')}}active{{/if}}" data-tab="body" style="height: 100%;">
        <section class="sheet-body" style="padding: 10px;">
            
            <fieldset class="item-fieldset">
                <legend>Magie d'Argyropée</legend>
                <div class="grid-fields">
                    <div class="form-group">
                        <label>Domaine magique :</label>
                        <select name="system.domain">
                            <option value="">-- Choisir --</option>
                            {{selectOptions spellDomains selected=system.domain localize=false}}
                        </select>
                    </div>
                    <div class="form-group highlight" style="background: rgba(74, 0, 100, 0.3); border-color: #d896ff;">
                        <label style="color: #e6ccff;">Coût en Panache :</label>
                        <input type="number" name="system.cost" value="{{system.cost}}" min="0" placeholder="Par défaut: 1">
                    </div>
                </div>
            </fieldset>

            <fieldset class="item-fieldset">
                <legend>Paramètres du sort</legend>
                <div class="grid-fields">
                    <div class="form-group">
                        <label>Portée :</label>
                        <input type="text" name="system.range" value="{{system.range}}" placeholder="ex: Contact, 10m...">
                    </div>
                    <div class="form-group">
                        <label>Zone d'effet :</label>
                        <input type="text" name="system.area" value="{{system.area}}" placeholder="ex: Cible unique, Sphère de 5m...">
                    </div>
                </div>

                <div class="grid-fields" style="margin-top: 15px;">
                    <div class="form-group row">
                        <label title="Autorise-t-il la victime à faire un jet pour résister ?">Résistance autorisée :</label>
                        <input type="checkbox" name="system.resist" {{checked system.resist}}>
                    </div>
                    <div class="form-group row">
                        <label title="Peut-on dépenser 1 Panache supplémentaire pour le lancer sans geste/parole ?">Lancement discret possible :</label>
                        <input type="checkbox" name="system.canBeDiscreet" {{checked system.canBeDiscreet}}>
                    </div>
                </div>
            </fieldset>
        </section>
    </div>

    {{!-- ONGLET 2 : EFFETS (Boutons dans le chat) --}}
    <div class="tab {{#if (eq tab.id 'effects')}}active{{/if}}" data-tab="effects" style="height: 100%;">
        <section class="sheet-body" style="padding: 10px;">
            <fieldset class="item-fieldset">
                <legend>Effets magiques (Boutons d'application)</legend>
                <p style="font-size: 0.85em; font-style: italic; color: wheat; margin-top: 0;">Les effets créés ici généreront un bouton "Appliquer" dans le chat lors du lancement du sort.</p>
                <div style="text-align: right; margin-bottom: 10px;">
                    <a class="item-control" data-action="addEffect" style="background: rgba(245, 222, 179, 0.2); color: wheat; padding: 5px 10px; border-radius: 3px; font-size: 0.9em; cursor: pointer; border: 1px solid wheat;"><i class="fas fa-plus"></i> Ajouter un Effet</a>
                </div>
                <ul class="items-list effects-list">
                    {{#each effects as |effect|}}
                    <li class="item effect flexrow" data-effect-id="{{effect.id}}">
                        <div class="item-name flexrow" style="display: flex; flex: 3; align-items: center; gap: 10px;">
                            <img src="{{effect.img}}" width="32" height="32" style="border: none; flex: 0 0 32px; object-fit: cover;" />
                            <span style="font-weight: bold; {{#if effect.disabled}}text-decoration: line-through; color: #777;{{/if}}">{{effect.name}}</span>
                        </div>
                        <div class="item-controls" style="font-size: 1.2em;">
                            <a class="item-control" data-action="toggleEffect" style="color: {{#if effect.disabled}}#777{{else}}wheat{{/if}};"><i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i></a>
                            <a class="item-control" data-action="editEffect" style="margin: 0 10px;"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteEffect" style="color: #ff6b6b;"><i class="fas fa-trash"></i></a>
                        </div>
                    </li>
                    {{/each}}
                </ul>
            </fieldset>
        </section>
    </div>
</div>