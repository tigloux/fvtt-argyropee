<div class="sheet-main-layout">

  {{!-- COLONNE GAUCHE : NAVIGATION LATÉRALE --}}
  {{> "systems/argyropee/templates/actor-nav.hbs"}}

  {{!-- COLONNE DROITE : CONTENU DES ONGLETS --}}
  <section class="sheet-body">

    {{!-- ONGLET 1 : COMPÉTENCES --}}
    <div class="tab {{#if (eq tab.id 'competences')}}active{{/if}}" data-tab="competences" data-group="primary">
        <div class="competences-grid">
        {{#each skillsData as |data key|}}
            <div class="comp-item">
            <button type="button" class="skill-roll-btn" data-action="rollComp" data-comp="{{key}}">
                {{data.label}}
            </button>
            <div class="skill-dots" data-comp-key="system.competences.{{key}}">
                {{#each data.dots as |dot|}}
                <span class="dot {{dot.cssClass}}" data-action="setSkill" data-value="{{dot.value}}" title="{{dot.tooltip}}"></span>
                {{/each}}
            </div>
            </div>
        {{/each}}
        </div>
    </div>

    {{!-- ONGLET 2 : COMBAT & MAGIE --}}
    <div class="tab tab-content-col {{#if (eq tab.id 'combat')}}active{{/if}}" data-tab="combat" data-group="primary">
        
        {{!-- ARMES EN MAIN (Équipées) --}}
        <fieldset class="sheet-box red">
            <legend class="sheet-legend"><i class="fas fa-swords"></i> Armes en main</legend>
            <ul class="items-list">
                <li class="items-header">
                    <div style="flex: 0 0 40px; text-align: center;" title="Déséquiper">Eqp.</div>
                    <div style="flex: 2;">Arme</div>
                    <div class="item-stat">Dégâts</div>
                    <div class="item-stat">Portée</div>
                    <div class="item-actions" style="flex: 0 0 60px;">Actions</div>
                </li>
                {{#each itemsByType.armesEquipees as |item|}}
                <li class="item" data-item-id="{{item.id}}">
                    <div style="flex: 0 0 40px; text-align: center;">
                        <a class="item-control item-equip" data-action="toggleEquip" title="Déséquiper et ranger" style="color: #4a0000; font-size: 1.2em;"><i class="fas fa-shield-alt"></i></a>
                    </div>
                    <div class="item-name">
                        <img src="{{item.img}}" width="28" height="28" />
                        <span style="color: #4a0000;">{{item.name}}</span>
                    </div>
                    <div class="item-stat bold">{{item.system.damage}}</div>
                    <div class="item-stat">{{#if (eq item.system.range 0)}}Mêlée{{else}}{{item.system.range}} m{{/if}}</div>
                    <div class="item-actions" style="flex: 0 0 60px;">
                        <a class="item-control" data-action="rollAttack" title="Attaquer" style="color: #4a0000; font-size: 1.2em;"><i class="fas fa-crosshairs"></i></a>
                        <a class="item-control" data-action="editItem" title="Détails" style="color: #555;"><i class="fas fa-edit"></i></a>
                    </div>
                </li>
                {{else}}
                <li style="text-align: center; color: #777; font-style: italic; padding: 10px;">Aucune arme en main. Le personnage combat à mains nues.</li>
                {{/each}}
            </ul>
        </fieldset>

        {{!-- PROTECTIONS PORTÉES (Équipées) --}}
        <fieldset class="sheet-box blue">
            <legend class="sheet-legend"><i class="fas fa-user-shield"></i> Protections Portées</legend>
            <ul class="items-list">
                <li class="items-header">
                    <div style="flex: 0 0 40px; text-align: center;" title="Déséquiper">Eqp.</div>
                    <div style="flex: 2;">Équipement</div>
                    <div class="item-stat">Type</div>
                    <div class="item-stat">Prot. (X)</div>
                    <div class="item-stat">Usure (Y)</div>
                    <div style="flex: 0 0 30px;"></div>
                </li>
                {{#each itemsByType.armuresEquipees as |item|}}
                <li class="item" data-item-id="{{item.id}}">
                    <div style="flex: 0 0 40px; text-align: center;">
                        <a class="item-control item-equip" data-action="toggleEquip" title="Retirer l'armure" style="color: #192a51; font-size: 1.2em;"><i class="fas fa-tshirt"></i></a>
                    </div>
                    <div class="item-name">
                        <img src="{{item.img}}" width="28" height="28" />
                        <span style="color: #192a51;">{{item.name}}</span>
                    </div>
                    <div class="item-stat">{{item.system.armorType}}</div>
                    <div class="item-stat bold">{{#if (eq item.system.armorType "Casque")}}-{{else}}{{item.system.protection}}{{/if}}</div>
                    <div class="item-stat" style="display: flex; justify-content: center; gap: 3px;">
                        {{#if (eq item.system.armorType "Casque")}}-{{else}}
                        <input type="number" data-action="updateItemY" value="{{item.system.resistance.value}}" style="width: 30px; height: 20px; text-align: center; border: 1px solid #000; {{#if (eq item.system.resistance.value 0)}}background: #ffcccc; color: darkred;{{/if}}">
                        <span>/</span><span>{{item.system.resistance.max}}</span>
                        {{/if}}
                    </div>
                    <div class="item-actions" style="flex: 0 0 30px; justify-content: flex-end;">
                        <a class="item-control" data-action="editItem" title="Détails" style="color: #555;"><i class="fas fa-edit"></i></a>
                    </div>
                </li>
                {{else}}
                <li style="text-align: center; color: #777; font-style: italic; padding: 10px;">Aucune protection portée.</li>
                {{/each}}
            </ul>
        </fieldset>

        {{!-- GRIMOIRE ET SORTS --}}
        <fieldset class="sheet-box purple" open>
            <legend class="sheet-legend" style="cursor: pointer; user-select: none;">
                <i class="fas fa-book-dead"></i> Grimoire & Magie
            </legend>
            <div style="margin-top: 15px;">
                <ul class="items-list">
                    <li class="items-header">
                        <div style="flex: 2;">Sortilège</div>
                        <div class="item-stat">Domaine</div>
                        <div class="item-stat">Coût (Panache)</div>
                        <div class="item-actions" style="flex: 0 0 60px;">Actions</div>
                    </li>
                    {{#each itemsByType.sort as |item|}}
                    <li class="item" data-item-id="{{item.id}}">
                        <div class="item-name">
                            <img src="{{item.img}}" width="28" height="28" style="border: 1px solid #4a0064;"/>
                            <span style="color: #4a0064;">{{item.name}}</span>
                        </div>
                        <div class="item-stat" style="color: #555; font-style: italic;">{{item.system.domain}}</div>
                        <div class="item-stat bold">{{item.system.cost}} <i class="fas fa-sun" style="color: #4a0000; font-size: 0.8em;"></i></div>
                        <div class="item-actions" style="flex: 0 0 60px;">
                            <a class="item-control" data-action="castSpell" title="Lancer" style="color: #4a0064; font-size: 1.2em;"><i class="fas fa-magic"></i></a>
                            <a class="item-control" data-action="editItem" title="Détails" style="color: #555;"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                        </div>
                    </li>
                    {{else}}
                    <li style="text-align: center; color: #777; font-style: italic; padding: 10px;">Le personnage ne connaît aucun sortilège.</li>
                    {{/each}}
                </ul>
            </div>
        </fieldset>
    </div>

    {{!-- ONGLET 3 : INVENTAIRE (Sac à dos) --}}
    <div class="tab tab-content-col {{#if (eq tab.id 'equipement')}}active{{/if}}" data-tab="equipement" data-group="primary">
        <div class="grid-2col">
            
            {{!-- COLONNE GAUCHE --}}
            <div class="tab-content-col">
                <fieldset class="sheet-box gray">
                    <legend class="sheet-legend"><i class="fas fa-box"></i> Armes Rangées</legend>
                    <ul class="items-list">
                        {{#each itemsByType.armesInventaire as |item|}}
                        <li class="item" data-item-id="{{item.id}}">
                            <div style="flex: 0 0 30px; text-align: center;">
                                <a class="item-control item-equip" data-action="toggleEquip" style="color: #999; font-size: 1.2em;"><i class="fas fa-shield-alt"></i></a>
                            </div>
                            <div class="item-name">
                                <img class="grayscale" src="{{item.img}}" width="24" height="24"/>
                                <span class="small" style="color: #555;">{{item.name}}</span>
                            </div>
                            <div class="item-actions" style="flex: 0 0 50px;">
                                <a class="item-control" data-action="editItem" style="color: #555;"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; font-size: 0.9em; padding: 5px;">Aucune arme dans le sac.</li>
                        {{/each}}
                    </ul>
                </fieldset>

                <fieldset class="sheet-box gray">
                    <legend class="sheet-legend"><i class="fas fa-box-open"></i> Protections Rangées</legend>
                    <ul class="items-list">
                        {{#each itemsByType.armuresInventaire as |item|}}
                        <li class="item" data-item-id="{{item.id}}">
                            <div style="flex: 0 0 30px; text-align: center;">
                                <a class="item-control item-equip" data-action="toggleEquip" style="color: #999; font-size: 1.2em;"><i class="fas fa-tshirt"></i></a>
                            </div>
                            <div class="item-name">
                                <img class="grayscale" src="{{item.img}}" width="24" height="24"/>
                                <span class="small" style="color: #555;">{{item.name}}</span>
                            </div>
                            <div class="item-actions" style="flex: 0 0 50px;">
                                <a class="item-control" data-action="editItem" style="color: #555;"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; font-size: 0.9em; padding: 5px;">Aucune armure de rechange.</li>
                        {{/each}}
                    </ul>
                </fieldset>

                <fieldset class="sheet-box light">
                    <legend class="sheet-legend" style="font-size: 1.1em;"><i class="fas fa-bullseye"></i> Munitions</legend>
                    <ul class="items-list">
                        {{#each itemsByType.munition as |item|}}
                        <li class="item" data-item-id="{{item.id}}">
                            <div class="item-name">
                                <img src="{{item.img}}" width="24" height="24" style="border: 1px solid #7a7971;"/>
                                <span class="small">{{item.name}}</span>
                            </div>
                            <div class="item-stat" style="display: flex; justify-content: center; gap: 8px; align-items: center;">
                                <a data-action="decreaseQuantity" style="color: darkred; font-size: 1.2em;"><i class="fas fa-minus-circle"></i></a>
                                <span class="bold" style="font-size: 1.2em; width: 30px;">{{item.system.quantity}}</span>
                                <a data-action="increaseQuantity" style="color: darkgreen; font-size: 1.2em;"><i class="fas fa-plus-circle"></i></a>
                            </div>
                            <div class="item-actions" style="flex: 0 0 50px;">
                                <a data-action="editItem" style="color: #555;"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; font-size: 0.9em; padding: 5px;">Pas de munitions.</li>
                        {{/each}}
                    </ul>
                </fieldset>
            </div>

            {{!-- COLONNE DROITE --}}
            <div class="tab-content-col">
                <fieldset class="sheet-box green">
                    <legend class="sheet-legend"><i class="fas fa-flask"></i> Apothicaire & Alchimie</legend>
                    <ul class="items-list">
                        {{#each itemsByType.consommable as |item|}}
                        <li class="item" data-item-id="{{item.id}}">
                            <div class="item-name">
                                <img src="{{item.img}}" width="24" height="24" style="border: 1px solid #004a2e;"/>
                                <span class="small" style="color: #004a2e;">{{item.name}}</span>
                            </div>
                            <div class="item-stat" style="display: flex; justify-content: center; gap: 5px;">
                                <a data-action="decreaseQuantity" style="color: darkred;"><i class="fas fa-minus-circle"></i></a>
                                <span class="bold" style="width: 20px;">{{item.system.quantity}}</span>
                                <a data-action="increaseQuantity" style="color: darkgreen;"><i class="fas fa-plus-circle"></i></a>
                            </div>
                            <div class="item-actions" style="flex: 0 0 70px;">
                                <a data-action="useConsumable" style="color: #004a2e; font-size: 1.3em;"><i class="fas fa-wine-bottle"></i></a>
                                <a data-action="editItem" style="color: #555;"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; font-size: 0.9em; padding: 5px;">Aucun consommable.</li>
                        {{/each}}
                    </ul>
                </fieldset>

                <fieldset class="sheet-box blue">
                    <legend class="sheet-legend"><i class="fas fa-cog"></i> Pièges & Mécanismes</legend>
                    <ul class="items-list">
                        {{#each itemsByType.piege as |item|}}
                        <li class="item" data-item-id="{{item.id}}">
                            <div class="item-name">
                                <img src="{{item.img}}" width="24" height="24" style="border: 1px solid #192a51;"/>
                                <span class="small" style="color: #192a51;">{{item.name}}</span>
                            </div>
                            <div class="item-stat" style="font-style: italic; font-size: 0.8em; color: {{#if (eq item.system.status 'Déployé')}}darkred{{else}}#555{{/if}};">
                                {{item.system.status}}
                            </div>
                            <div class="item-actions" style="flex: 0 0 70px;">
                                <a data-action="deployTrap" style="color: #192a51; font-size: 1.3em;"><i class="fas fa-tools"></i></a>
                                <a data-action="editItem" style="color: #555;"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; font-size: 0.9em; padding: 5px;">Aucun mécanisme.</li>
                        {{/each}}
                    </ul>
                </fieldset>
            </div>
        </div>

        {{!-- BLOC DU BAS : Richesses & Encombrement --}}
        <div style="display: flex; gap: 20px;">
            <fieldset class="sheet-box gold" style="flex: 2;">
                <legend class="sheet-legend"><i class="fas fa-coins"></i> Bourse & Richesses</legend>
                <div class="wealth-boxes">
                    <div class="wealth-item" style="background: rgba(255, 215, 0, 0.1); border: 1px solid #ffd700;">
                        <label style="font-weight: bold; color: #b8860b; font-size: 0.9em;">Lingots</label>
                        <input type="number" name="system.richesse.lingots" value="{{system.richesse.lingots}}" min="0">
                    </div>
                    <div class="wealth-item" style="background: rgba(192, 192, 192, 0.1); border: 1px solid #c0c0c0;">
                        <label style="font-weight: bold; color: #555; font-size: 0.9em;">Florins</label>
                        <input type="number" name="system.richesse.florins" value="{{system.richesse.florins}}" min="0">
                    </div>
                    <div class="wealth-item" style="background: rgba(205, 127, 50, 0.1); border: 1px solid #cd7f32;">
                        <label style="font-weight: bold; color: #8b4513; font-size: 0.9em;">Deniers</label>
                        <input type="number" name="system.richesse.deniers" value="{{system.richesse.deniers}}" min="0">
                    </div>
                    <div class="wealth-item" style="background: rgba(139, 69, 19, 0.1); border: 1px solid #8b4513;">
                        <label style="font-weight: bold; color: #5c3a21; font-size: 0.9em;">Sous</label>
                        <input type="number" name="system.richesse.sous" value="{{system.richesse.sous}}" min="0">
                    </div>
                </div>
                <div style="text-align: center; margin-top: 10px; font-size: 1.1em;">
                    Fortune totale estimée : <b style="color: #004a2e;">{{totalSous}} sous</b>
                </div>
            </fieldset>

            <fieldset class="sheet-box dark" style="flex: 1;">
                <legend class="sheet-legend"><i class="fas fa-weight-hanging"></i> Charge Portée</legend>
                <div style="font-size: 1.5em; text-align: center; margin-bottom: 5px;">
                    <b style="color: {{#if (gt system.poidsTotal system.chargeLegere)}}darkred{{else}}#004a2e{{/if}};">{{system.poidsTotal}}</b> 
                    <span style="font-size: 0.7em; color: #555;">/ {{system.chargeLegere}} kg</span>
                </div>
                <div style="font-size: 0.8em; color: {{#if (gt system.poidsTotal system.chargeLegere)}}darkred{{else}}#555{{/if}}; text-align: center; font-style: italic;">
                    {{#if (gt system.poidsTotal system.chargeLegere)}}Le personnage est encombré !{{else}}Charge légère.{{/if}}
                </div>
            </fieldset>
        </div>
    </div>

    {{!-- ONGLET 5 : BACKGROUND --}}
    <div class="tab tab-content-col {{#if (eq tab.id 'background')}}active{{/if}}" data-tab="background" data-group="primary">
        
        <fieldset class="sheet-box light">
            <legend class="sheet-legend"><i class="fas fa-id-card"></i> État Civil</legend>
            <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 80px;">
                    <label style="font-size: 0.8em; font-weight: bold; text-transform: uppercase;">Sexe</label>
                    <input class="line-input" name="system.biographie.sexe" type="text" value="{{system.biographie.sexe}}"/>
                </div>
                <div style="flex: 1; min-width: 80px;">
                    <label style="font-size: 0.8em; font-weight: bold; text-transform: uppercase;">Âge</label>
                    <input class="line-input" name="system.biographie.age" type="number" value="{{system.biographie.age}}"/>
                </div>
                <div style="flex: 1; min-width: 80px;">
                    <label style="font-size: 0.8em; font-weight: bold; text-transform: uppercase;">Taille</label>
                    <input class="line-input" name="system.biographie.taille" type="text" value="{{system.biographie.taille}}"/>
                </div>
                <div style="flex: 1; min-width: 80px;">
                    <label style="font-size: 0.8em; font-weight: bold; text-transform: uppercase;">Poids</label>
                    <input class="line-input" name="system.biographie.poids" type="text" value="{{system.biographie.poids}}"/>
                </div>

                <div class="citoyennete-drop" style="flex: 2; min-width: 200px; border: 1px dashed #192a51; padding: 5px; background: rgba(25, 42, 81, 0.05); text-align: center; position: relative;">
                    <label style="font-size: 0.8em; font-weight: bold; text-transform: uppercase; color: #192a51; position: absolute; top: -20px; left: 10px; padding: 0 5px;">Citoyenneté</label>
                    {{#each itemsByType.citoyennete as |item|}}
                    <div class="item" data-item-id="{{item.id}}" style="display: flex; justify-content: center; align-items: center; gap: 10px;">
                        <span style="font-family: 'Renaiss', serif; font-size: 1.4em; font-weight: bold; color: #004a2e;">{{item.name}}</span>
                        <div class="item-controls" style="font-size: 0.9em;">
                            <a data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a data-action="deleteItem" style="color: darkred; margin-left: 5px;"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    {{else}}
                    <div style="color: #777; font-style: italic; font-size: 0.9em; padding-top: 5px;">Glisser une origine depuis le compendium ici</div>
                    {{/each}}
                </div>
            </div>
        </fieldset>

        <fieldset class="sheet-box green">
            <legend class="sheet-legend"><i class="fas fa-hammer"></i> Carrière & Métiers</legend>
            <ul class="items-list">
                <li class="items-header">
                    <div style="flex: 0 0 40px; text-align: center;" title="Métier actuellement exercé">Actif</div>
                    <div style="flex: 2;">Métier</div>
                    <div style="flex: 2; text-align: center;">Bonus Accordé</div>
                    <div class="item-stat">Rang</div>
                    <div class="item-stat">Salaire / jour</div>
                    <div style="flex: 0 0 50px;"></div>
                </li>
                {{#each itemsByType.metier as |item|}}
                <li class="item" data-item-id="{{item.id}}">
                    <div style="flex: 0 0 40px; text-align: center;">
                        <a class="item-control" data-action="toggleActiveMetier" style="font-size: 1.2em; color: {{#if item.system.isActive}}#d4af37{{else}}#ccc{{/if}};">
                            <i class="{{#if item.system.isActive}}fas{{else}}far{{/if}} fa-star"></i>
                        </a>
                    </div>
                    <div class="item-name">
                        <img src="{{item.img}}" width="28" height="28" />
                        <span style="{{#if item.system.isActive}}color: #004a2e;{{/if}}">{{item.name}}</span>
                    </div>
                    <div style="flex: 2; text-align: center; font-size: 0.9em;">
                        {{#if item.system.chosenBonusSkill}}
                            +1 en <b>{{item.system.chosenBonusSkill}}</b>
                        {{else}}
                            <i style="color: #777;">Aucun</i>
                        {{/if}}
                    </div>
                    <div class="item-stat bold">{{item.system.rank}}</div>
                    <div class="item-stat">{{item.system.dailyWage}} <i class="fas fa-coins" style="color: #8b4513; font-size: 0.8em;"></i></div>
                    <div class="item-actions" style="flex: 0 0 50px; justify-content: flex-end; gap: 5px;">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem" style="color: darkred;"><i class="fas fa-trash"></i></a>
                    </div>
                </li>
                {{else}}
                <li style="padding: 10px; font-style: italic; text-align: center; color: #555;">Aucun métier pour le moment. (Vagabond)</li>
                {{/each}}
            </ul>
        </fieldset>

        <fieldset class="sheet-box light" style="border-color: #000;">
            <legend class="sheet-legend" style="color: #4a0064;"><i class="fas fa-book-open"></i> Histoire & Cercles Intimes</legend>
            <div class="grid-2col">
                <div class="tab-content-col" style="gap: 15px;">
                    <div>
                        <b style="color: #192a51; border-bottom: 1px solid #192a51; display: block; margin-bottom: 5px;">Description Physique</b>
                        <prose-mirror name="system.background.physique" value="{{system.background.physique}}" toggled="true">
                            {{{enrichedPhysique}}}
                        </prose-mirror>
                    </div>
                    <div>
                        <b style="color: darkred; border-bottom: 1px solid darkred; display: block; margin-bottom: 5px;">Amours</b>
                        <prose-mirror name="system.background.amours" value="{{system.background.amours}}" toggled="true">
                            {{{enrichedAmours}}}
                        </prose-mirror>
                    </div>
                    <div>
                        <b style="color: #555; border-bottom: 1px solid #555; display: block; margin-bottom: 5px;">Ennemis</b>
                        <prose-mirror name="system.background.ennemis" value="{{system.background.ennemis}}" toggled="true">
                            {{{enrichedEnnemis}}}
                        </prose-mirror>
                    </div>
                </div>
                <div class="tab-content-col" style="gap: 15px;">
                    <div>
                        <b style="color: #004a2e; border-bottom: 1px solid #004a2e; display: block; margin-bottom: 5px;">Famille</b>
                        <prose-mirror name="system.background.famille" value="{{system.background.famille}}" toggled="true">
                            {{{enrichedFamille}}}
                        </prose-mirror>
                    </div>
                    <div>
                        <b style="color: #004a2e; border-bottom: 1px solid #004a2e; display: block; margin-bottom: 5px;">Amis</b>
                        <prose-mirror name="system.background.amis" value="{{system.background.amis}}" toggled="true">
                            {{{enrichedAmis}}}
                        </prose-mirror>
                    </div>
                    <div>
                        <b style="color: #8b4513; border-bottom: 1px solid #8b4513; display: block; margin-bottom: 5px;">Réseau Professionnel</b>
                        <prose-mirror name="system.background.travail" value="{{system.background.travail}}" toggled="true">
                            {{{enrichedTravail}}}
                        </prose-mirror>
                    </div>
                </div>
            </div>
        </fieldset>

    </div>

    {{!-- ONGLET 6 : SANTÉ & ÉTATS --}}
    <div class="tab {{#if (eq tab.id 'etats')}}active{{/if}}" data-tab="etats" data-group="primary" style="padding-top: 10px;">
        <div class="grid-2col">
            
            <div class="tab-content-col">
                <fieldset class="sheet-box red">
                    <legend class="sheet-legend" style="color: darkred;"><i class="fas fa-user-injured"></i> États Préjudiciables</legend>
                    <p style="font-size: 0.85em; font-style: italic; color: #555; margin-top: 0; margin-bottom: 10px;">Altérations physiques et morales générales (Fatigue, Hémorragie...).</p>
                    <ul class="items-list">
                        {{#each systemEffects as |effect|}}
                        <li class="effect-card" data-effect-id="{{effect.id}}">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <img src="{{effect.img}}" width="28" height="28" style="border: none;"/>
                                <b style="color: darkred; font-size: 1.1em;">{{effect.name}}</b>
                            </div>
                            <a data-action="deleteEffect" title="Retirer l'état" style="cursor: pointer; color: #555; font-size: 1.2em;"><i class="fas fa-times-circle"></i></a>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; padding: 10px; border: 1px dashed #ccc; background: white;">
                            Aucun état préjudiciable actif.
                        </li>
                        {{/each}}
                    </ul>
                </fieldset>

                <fieldset class="sheet-box green">
                    <legend class="sheet-legend"><i class="fas fa-magic"></i> Effets d'Objets & Sorts</legend>
                    <p style="font-size: 0.85em; font-style: italic; color: #555; margin-top: 0; margin-bottom: 10px;">Bénédictions, malédictions ou poisons actifs.</p>
                    <ul class="items-list">
                        {{#each itemEffects as |effect|}}
                        <li class="effect-card" data-effect-id="{{effect.id}}">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <img src="{{effect.img}}" width="28" height="28" style="border: none;"/>
                                <b style="color: #004a2e; font-size: 1.1em;">{{effect.name}}</b>
                            </div>
                            <a data-action="deleteEffect" title="Retirer l'effet" style="cursor: pointer; color: #555; font-size: 1.2em;"><i class="fas fa-times-circle"></i></a>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; padding: 10px; border: 1px dashed #ccc; background: white;">
                            Aucun effet d'objet actif.
                        </li>
                        {{/each}}
                    </ul>
                </fieldset>
            </div>

            <div class="tab-content-col">
                <fieldset class="sheet-box red" style="height: 100%;">
                    <legend class="sheet-legend"><i class="fas fa-biohazard"></i> Maladies & Afflictions</legend>
                    <p style="font-size: 0.85em; font-style: italic; color: #555; margin-top: 0; margin-bottom: 10px;">Suivi des pathologies à long terme nécessitant des jets quotidiens.</p>
                    
                    <ul class="items-list">
                        {{#each itemsByType.maladie as |item|}}
                        <li class="disease-card" data-item-id="{{item.id}}">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <img src="{{item.img}}" width="36" height="36" style="border-radius: 5px; border: 1px solid #4a0000;">
                                    <div>
                                        <b style="color: #4a0000; font-size: 1.2em; font-family: 'Renaiss', serif;">{{item.name}}</b><br>
                                        <span style="font-size: 0.85em; color: #555; font-style: italic;">Origine : {{item.system.origin}}</span>
                                    </div>
                                </div>
                                <div class="item-actions" style="gap: 8px;">
                                    <a data-action="editItem" style="cursor: pointer; color: #555; font-size: 1.1em;"><i class="fas fa-edit"></i></a>
                                    <a data-action="deleteItem" style="cursor: pointer; color: darkred; font-size: 1.1em;"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 8px; border-top: 1px dashed #ccc; padding-top: 8px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: bold; color: #004a2e;">
                                        Progression : {{item.system.testsPassed}} / {{item.system.testsRequired}}
                                    </span>
                                    <button type="button" data-action="addDiseaseSuccess" style="width: auto; padding: 2px 8px; font-size: 0.9em; background: #004a2e; color: white; border: none; border-radius: 3px; cursor: pointer;">
                                        <i class="fas fa-plus"></i> Succès
                                    </button>
                                </div>
                                <button type="button" class="disease-btn" data-action="rollDisease">
                                    <i class="fas fa-dice"></i> Lancer le jet quotidien
                                </button>
                                {{#if item.system.treatment}}
                                <div style="font-size: 0.85em; font-style: italic; color: #777; margin-top: 5px; background: #f9f9f9; padding: 5px; border-radius: 3px; border-left: 3px solid #d4af37;">
                                    <b>Traitement :</b> {{item.system.treatment}}
                                </div>
                                {{/if}}
                            </div>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #004a2e; font-style: italic; padding: 20px; border: 1px dashed #ccc; background: white;">
                            <i class="fas fa-check-circle" style="font-size: 2em; margin-bottom: 10px; display: block;"></i>
                            Le personnage est en parfaite santé.
                        </li>
                        {{/each}}
                    </ul>
                </fieldset>
            </div>
        </div>
    </div>

  </section>
</div>