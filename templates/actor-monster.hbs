<div class="actor-sheet-wrapper" style="display: flex; flex-direction: column; height: 100%; padding: 10px;">
    
    {{!-- HEADER MONSTRE --}}
    <header style="display: flex; gap: 15px; margin-bottom: 15px; border-bottom: 2px solid #cccdcf; padding-bottom: 10px;">
        <div class="portrait-wrapper" style="margin-left: 0; margin-top: 25px; width: 155px; height: 230px;">
            <img class="portrait-img" src="{{actor.img}}" data-action="editImage" title="Modifier le portrait" />
            <div class="portrait-frame monster-frame"></div>
        </div>
        <div style="flex: 1;">
            <input type="text" name="name" value="{{actor.name}}" style="font-family: 'Renaiss'; font-size: 2em; font-weight: bold; border: none; border-bottom: 1px solid #ccc; width: 100%; margin-bottom: 10px; color: darkred;" placeholder="Nom de la créature">
            
            <div style="display: flex; gap: 10px;">
                <div style="flex: 1; text-align: center; background: rgba(74,0,0,0.1); padding: 5px; border-radius: 5px; border: 1px solid darkred;">
                    <b style="color: darkred;"><i class="fas fa-skull"></i> Santé (Mort à 0)</b><br>
                    <input type="number" name="system.health.value" value="{{system.health.value}}" style="width: 40px; text-align: center; font-weight: bold;"> / 
                    <input type="number" name="system.health.max" value="{{system.health.max}}" style="width: 40px; text-align: center;">
                </div>
                <div style="flex: 1; text-align: center; background: rgba(0,0,0,0.05); padding: 5px; border-radius: 5px;">
                    <b><i class="fas fa-shield-alt"></i> Protection (X)</b><br>
                    <input type="number" name="system.protection" value="{{system.protection}}" style="width: 50px; text-align: center; margin-top: 2px;">
                </div>
                <div style="flex: 1; text-align: center; background: rgba(0,0,0,0.05); padding: 5px; border-radius: 5px;">
                    <b><i class="fas fa-bolt"></i> Bonus Init.</b><br>
                    <input type="number" name="system.initiativeBonus" value="{{system.initiativeBonus}}" style="width: 50px; text-align: center; margin-top: 2px;">
                </div>
            </div>
            {{!-- STATISTIQUES MONSTRUEUSES --}}
            <fieldset style="border: 1px solid #000; padding: 10px; margin-bottom: 15px; margin-top: 10px;">
                <legend style="font-weight: bold;">Profil de la créature</legend>
                <div style="display: flex; gap: 15px; margin-bottom: 10px;">
                    <label style="flex: 1;"><b>Habitat :</b> <input type="text" name="system.environment" value="{{system.environment}}" style="width: 100%;"></label>
                    <label style="flex: 1; color: darkred;"><b>Faiblesses :</b> <input type="text" name="system.weaknesses" value="{{system.weaknesses}}" style="width: 100%;"></label>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #ccc; padding-top: 10px;">
                    <div style="display: flex; gap: 10px;">
                        <b>Vitesses (m/s) :</b>
                        <label>Sol <input type="number" step="0.1" name="system.movement.sol" value="{{system.movement.sol}}" style="width: 40px;"></label>
                        <label>Vol <input type="number" step="0.1" name="system.movement.vol" value="{{system.movement.vol}}" style="width: 40px;"></label>
                        <label>Nage <input type="number" step="0.1" name="system.movement.nage" value="{{system.movement.nage}}" style="width: 40px;"></label>
                    </div>
                    <label style="font-weight: bold; background: #ffcccc; padding: 3px 8px; border-radius: 4px; color: darkred;">
                        <input type="checkbox" name="system.isSwarm" {{checked system.isSwarm}}> Est une Nuée
                    </label>
                </div>
            </fieldset>
        </div>
        
    </header>

    

    {{!-- ONGLETS DYNAMIQUES --}}
    <nav class="sheet-tabs tabs" data-group="primary" style="display: flex; flex-direction: row; justify-content: center; flex-wrap: wrap; gap: 15px; margin-bottom: 15px; border-bottom: transparent;">
        {{#each tabs.primary.tabs as |tab|}}
        <a class="item {{tab.cssClass}} nav-btn" data-tab="{{tab.id}}" data-group="primary" data-action="setTab" style="margin-bottom: 0; padding-left: 0; justify-content: center;">
            {{tab.label}}
        </a>
        {{/each}}
    </nav>

    <section class="sheet-body" style="flex: 1; overflow-y: auto;">
        
        <div class="tab {{#if (eq tab.id 'skills')}}active{{/if}}" data-tab="skills" data-group="primary">
            <p style="font-style: italic; font-size: 0.9em; color: #555; text-align: center;">Cochez les compétences privilégiées (lance 1d6 complet). Celles non cochées lanceront 1d6 divisé par 2.</p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
                {{#each skillsList as |label key|}}
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding: 2px;">
                    <a data-action="rollComp" data-comp="{{key}}" style="cursor: pointer; color: #000;">
                        <i class="fas fa-dice-d10" style="color: darkred;"></i> <b>{{label}}</b>
                    </a>
                    <input type="checkbox" name="system.skills.{{key}}" {{checked (lookup ../system.skills key)}}>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="tab {{#if (eq tab.id 'attacks')}}active{{/if}}" data-tab="attacks" data-group="primary">
            <p style="font-style: italic; font-size: 0.9em; color: #555; text-align: center;">Créez des "Armes" (ex: Griffes, Morsure, Tentacule) avec la compétence "Rixe" associée, et glissez-les ici.</p>
            <ul class="items-list">
                {{#each itemsByType.arme as |item|}}
                <li class="item flexrow" data-item-id="{{item.id}}" style="display: flex; justify-content: space-between; border-bottom: 1px solid #ccc; padding: 5px; background: rgba(0,0,0,0.05);">
                    <div>
                        <a data-action="rollAttack" style="color: darkred; margin-right: 5px; cursor: pointer;"><i class="fas fa-crosshairs"></i></a>
                        <b>{{item.name}}</b> (Dégâts: {{item.system.damage}})
                    </div>
                    <div class="item-controls">
                        <a class="item-control" data-action="editItem" style="cursor: pointer;"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem" style="cursor: pointer;"><i class="fas fa-trash"></i></a>
                    </div>
                </li>
                {{/each}}
            </ul>
        </div>

        {{!-- ONGLET NOTES --}}
        <div class="tab {{#if (eq tab.id 'notes')}}active{{/if}}" data-tab="notes" data-group="primary">
            <div class="grid-2col">
                <div class="tab-content-col">
                    <fieldset class="sheet-box gray" style="border-color: #000;">
                        <legend class="sheet-legend"><i class="fas fa-book-open"></i> Notes</legend>
                        <div>
                            <prose-mirror name="system.biographie.notes" value="{{system.biographie.notes}}" toggled="true">
                                {{{enrichedNotes}}}
                            </prose-mirror>
                        </div>
                    </fieldset>
                </div>
                <div class="tab-content-col">
                <fieldset class="sheet-box red">
                    <legend class="sheet-legend" style="color: darkred;"><i class="fas fa-user-injured"></i> États Préjudiciables</legend>
                    <p style="font-size: 0.85em; font-style: italic; color: #555; margin-top: 0; margin-bottom: 10px;">Altérations physiques et morales générales (Fatigue, Hémorragie...).</p>
                    <ul class="items-list">
                        {{#each systemEffects as |effect|}}
                        <li class="effect-card" data-effect-id="{{effect.id}}">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <img src="{{effect.img}}" width="28" height="28" style="border: none;"/>
                                <b style="color: darkred; font-size: 1.1em;">{{effect.name}}</b>
                            </div>
                            <a data-action="deleteEffect" title="Retirer l'état" style="cursor: pointer; color: #555; font-size: 1.2em;"><i class="fas fa-times-circle"></i></a>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; padding: 10px; border: 1px dashed #ccc; background: white;">
                            Aucun état préjudiciable actif.
                        </li>
                        {{/each}}
                    </ul>
                </fieldset>

                <fieldset class="sheet-box green">
                    <legend class="sheet-legend"><i class="fas fa-magic"></i> Effets d'Objets & Sorts</legend>
                    <p style="font-size: 0.85em; font-style: italic; color: #555; margin-top: 0; margin-bottom: 10px;">Bénédictions, malédictions ou poisons actifs.</p>
                    <ul class="items-list">
                        {{#each itemEffects as |effect|}}
                        <li class="effect-card" data-effect-id="{{effect.id}}">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <img src="{{effect.img}}" width="28" height="28" style="border: none;"/>
                                <b style="color: #004a2e; font-size: 1.1em;">{{effect.name}}</b>
                            </div>
                            <a data-action="deleteEffect" title="Retirer l'effet" style="cursor: pointer; color: #555; font-size: 1.2em;"><i class="fas fa-times-circle"></i></a>
                        </li>
                        {{else}}
                        <li style="text-align: center; color: #777; font-style: italic; padding: 10px; border: 1px dashed #ccc; background: white;">
                            Aucun effet d'objet actif.
                        </li>
                        {{/each}}
                    </ul>
                </fieldset>
            </div>
            </div>
        </div>
    </section>
</div>